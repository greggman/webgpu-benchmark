{
  "name": "webgpu-benchmark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A benchmark for the WebGPU implementation (not the GPU itself).",
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "node scripts/dev.mjs",
    "serve": "node scripts/serve.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "baseline": "node scripts/gen-baseline.mjs",
    "test": "node --test \"test/**/*.test.mjs\""
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.70",
    "esbuild": "^0.28.1",
    "gts": "^7.0.0",
    "puppeteer": "^25.1.0",
    "typescript": "^6.0.3"
  }
}
